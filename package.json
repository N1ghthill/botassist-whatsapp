{
  "name": "botassist-whatsapp",
  "version": "4.2.6",
  "description": "BotAssist - Assistente WhatsApp IA com Interface Gráfica",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:win": "electron-builder --win",
    "build:win:dir": "electron-builder --win --dir --publish never",
    "build:mac": "electron-builder --mac",
    "build:mac:dir": "electron-builder --mac --dir --publish never",
    "build:linux": "bash scripts/build-linux.sh",
    "build:linux:appimage": "electron-builder --linux AppImage --publish never",
    "build:linux:rpm": "bash scripts/build-rpm.sh",
    "build:linux:dir": "electron-builder --linux AppImage deb --dir --publish never",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html,json,md}\"",
    "test": "node scripts/test.js",
    "smoke:packaged": "node scripts/smoke-packaged.js",
    "release:manifest": "node scripts/render-release-manifest.js",
    "release:notes": "node scripts/render-release-notes.js",
    "release:signing:check": "node scripts/check-signing-readiness.js",
    "release:signing:provision": "node scripts/provision-signing-secrets.js",
    "release:verify": "node scripts/verify-release-assets.js",
    "reset": "node scripts/maintenance.js reset",
    "backup": "node scripts/maintenance.js backup",
    "clean": "node scripts/maintenance.js clean && npm i"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@whiskeysockets/baileys": "^7.0.0-rc12",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "groq-sdk": "^0.7.0",
    "imap": "^0.8.19",
    "keytar": "^7.9.0",
    "mailparser": "^3.9.11",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@electron/asar": "^4.1.0",
    "@eslint/js": "^9.39.4",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.4.2"
  },
  "author": "Irving Ruas <irving@ruas.dev.br>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/N1ghthill/botassist-whatsapp.git"
  },
  "overrides": {
    "file-type": "21.3.3",
    "flatted": "3.4.2",
    "form-data": "4.0.6",
    "ip-address": "10.2.0",
    "nodemailer": "9.0.1",
    "protobufjs": "7.6.3",
    "@protobufjs/utf8": "1.1.1",
    "music-metadata": "11.12.3",
    "tar": "7.5.16",
    "tmp": "0.2.7",
    "utf7": {
      "semver": "5.7.2"
    },
    "ws": "8.21.0"
  },
  "build": {
    "appId": "br.dev.ruas.botassist",
    "productName": "BotAssist WhatsApp",
    "icon": "assets/icon.png",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "**/*",
      "!dist/**",
      "!backups/**",
      "!.git/**",
      "!.github/**",
      "!docs/**",
      "!scripts/**",
      "!README.md",
      "!CONTRIBUTING.md",
      "!CODE_OF_CONDUCT.md",
      "!SECURITY.md",
      "!**/.env",
      "!**/.env.*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "N1ghthill",
        "repo": "botassist-whatsapp",
        "releaseType": "release"
      }
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "grantFileProtocolExtraPrivileges": false
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": "dmg"
    },
    "linux": {
      "category": "Utility",
      "icon": "assets/icons",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    }
  }
}
